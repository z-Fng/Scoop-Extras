            "hash": "e96dd421ecd4de9894440dc908e268970c2edb6a2e974251403265f641d15d18",
            "pre_install": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\""
        },
        "arm64": {
